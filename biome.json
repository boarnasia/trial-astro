{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "includes": [
      "src/**/*.{ts,tsx,js,jsx,mjs,json}",
      "scripts/**/*.{js,mjs,ts}",
      "*.json",
      "!**/*.astro",
      "!dist/**",
      "!.astro/**",
      "!node_modules/**",
      "!storybook-static/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
