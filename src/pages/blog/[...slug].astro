---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import FormattedDate from '@/components/ui/FormattedDate.astro';
import HeroBlock from '@/components/ui/HeroBlock';
import Typography from '@/components/ui/Typography';
import Layout from '@/layouts/Layout.astro';
import ContainerLayout from '@/components/layouts/ContainerLayout';
import { PageLayout } from '@/components/pages/blog/PageLayout';
import { HeroLayout } from '@/components/pages/blog/HeroLayout';
import { HeaderLayout } from '@/components/pages/blog/HeaderLayout';
import { BodyLayout } from '@/components/pages/blog/BodyLayout';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, heroImage } = post.data;
---

<Layout title={title} description={description}>
  <PageLayout as="article" variant={heroImage ? 'with-hero' : 'without-hero'}>
    {heroImage && (
      <HeroLayout>
        <HeroBlock src={heroImage} alt="" width={1020} height={510} />
      </HeroLayout>
    )}
    <HeaderLayout>
      <Typography as="p" variant="muted">
        <FormattedDate date={pubDate} />
        {updatedDate && (
          <Fragment>
            {' ・ Last updated on '}
            <FormattedDate date={updatedDate} />
          </Fragment>
        )}
      </Typography>
      <Typography as="h1" variant="display">{title}</Typography>
      <Typography as="p" variant="lead">{description}</Typography>
    </HeaderLayout>
    <BodyLayout>
      <ContainerLayout size="sm">
        <Content />
      </ContainerLayout>
    </BodyLayout>
  </PageLayout>
</Layout>
