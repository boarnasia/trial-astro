---
import { Image } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import BlogSearch from '@/components/BlogSearch';
import FormattedDate from '@/components/FormattedDate.astro';
import Pagination from '@/components/Pagination';
import Typography from '@/components/Typography';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import Layout from '@/layouts/Layout.astro';
import LayoutContainer from '@/components/Layouts/LayoutContainer';
import { LayoutPage } from '@/components/Layouts/Blog/LayoutPage';
import { LayoutHeader } from '@/components/Layouts/Blog/LayoutHeader';
import { LayoutBody } from '@/components/Layouts/Blog/LayoutBody';
import styles from './post-list.module.scss';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(posts, { pageSize: 10 });
};

const { page } = Astro.props as {
  page: {
    data: CollectionEntry<'blog'>[];
    currentPage: number;
    lastPage: number;
    url: {
      prev?: string;
      next?: string;
    };
  };
};

const allPosts = await getCollection('blog');
const allPostsMeta = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => ({
    id: post.id,
    title: post.data.title,
    description: post.data.description,
    pubDate: post.data.pubDate.toISOString(),
  }));
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <LayoutPage variant="without-hero">
    <LayoutHeader>
      <Typography as="p" variant="eyebrow">Blog</Typography>
      <Typography as="h1" variant="display">記事一覧</Typography>
      <Typography as="p" variant="lead">
        MDX で管理された記事を、検索とページングで快適に読めるようにしています。
      </Typography>
    </LayoutHeader>
    <LayoutBody>
      <LayoutContainer size="md">
        <BlogSearch posts={allPostsMeta} client:load />
        <ul class={styles.postList}>
          {
            page.data.map((post, index) => (
              <li class={[styles.postListItem, index === 0 && page.currentPage === 1 && styles.postListItemFeatured].filter(Boolean).join(' ')}>
                <a class={styles.postListLink} href={`/blog/${post.id}/`}>
                  {post.data.heroImage && (
                    <Image
                      class={styles.postCardImage}
                      width={720}
                      height={360}
                      src={post.data.heroImage}
                      alt=""
                    />
                  )}
                  <h4 class={styles.postCardTitle}>{post.data.title}</h4>
                  <p class={styles.postCardDate}>
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                </a>
              </li>
            ))
          }
        </ul>
        <Pagination
          currentPage={page.currentPage}
          lastPage={page.lastPage}
          prevUrl={page.url.prev}
          nextUrl={page.url.next}
        />
      </LayoutContainer>
    </LayoutBody>
  </LayoutPage>
</Layout>
