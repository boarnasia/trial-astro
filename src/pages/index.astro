---
import Layout from '@/layouts/Layout.astro';
import ContainerLayout from '@/components/layouts/ContainerLayout';
import Typography from '@/components/ui/Typography';
import MainBackgroundFull from '@/components/layouts/MainBackgroundFull';
import MovingLights02 from '@/components/ui/backgroundImage/MovingLights02';
import { SITE_DESCRIPTION, SITE_TITLE } from '@/consts';
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<MainBackgroundFull slot="first-element-of-body">
		<MovingLights02 />
	</MainBackgroundFull>
	<ContainerLayout size="sm">
		<Typography as="p" variant="eyebrow">Trial Astro</Typography>
		<Typography as="h1" variant="display">MDX 中心の軽量ブログ</Typography>
		<Typography as="p" variant="lead">
			Astro と React をベースに、検索しやすく保守しやすい構成へ整えたブログです。
		</Typography>
		<Typography as="p" variant="body">
			記事本文は MDX に統一し、一覧では検索ダイアログとページングで目的の記事へすばやく移動できます。
		</Typography>
		<ul>
			<li><a href="/blog/">ブログ一覧を見る</a></li>
			<li><a href="/about/">このサイトについて</a></li>
		</ul>
	</ContainerLayout>
</Layout>
